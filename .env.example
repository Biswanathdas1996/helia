# --- Core ---
MONGODB_URI=mongodb+srv://USER:PASS@HOST/helia
SESSION_SECRET=change-me-32-bytes-min

# --- PwC GenAI gateway (sole LLM + embeddings provider) ---
PWC_AI_API_KEY=
PWC_TOKEN=
PWC_CHAT_MODEL=vertex_ai.gemini-2.5-flash-image
# Optional comma-separated fallback list used when the configured model is unsupported.
PWC_CHAT_MODEL_FALLBACKS=vertex_ai.gemini-2.5-flash-image
PWC_EMBEDDING_MODEL=vertex_ai.gemini-embedding

# --- Atlas Vector Search ---
# Set to "true" once the chunks_vector_index has been created in Atlas
# (see infra/atlas-vector-index.json). Without this hybrid retrieval
# silently falls back to BM25-only.
MONGODB_VECTOR_SEARCH=false
MONGODB_VECTOR_INDEX=chunks_vector_index
# Vertex AI gemini-embedding outputs 768 dimensions by default. Override
# only if you switch the embedding model.
EMBEDDING_DIM=768

# --- Cache ---
# Optional. When unset the app uses an in-process LRU (single-replica only).
REDIS_URL=

# --- Rate limits (per minute, per user/IP) ---
RATE_LIMIT_CHAT=30
RATE_LIMIT_AUTH=10
RATE_LIMIT_DEFAULT=120

# --- Retrieval tuning ---
# Set to "true" to disable the LLM rerank pass (faster, slightly less accurate).
DISABLE_RERANK=false
DISABLE_QUERY_REWRITE=false

# --- Zoho Desk (optional; REST OAuth)
# Python-style names → env: zoho_base_url → ZOHO_BASE_URL, zoho_org_id → ZOHO_ORG_ID, etc.
ZOHO_BASE_URL=https://desk.zoho.com/api/v1
ZOHO_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DEPARTMENT_ID=
ZOHO_CONTACT_ID=
# If the signed-in user has no email or Desk blocks their domain, use an inbox allowed by Desk rules:
ZOHO_DEFAULT_REQUESTER_EMAIL=
ZOHO_ACCOUNTS_DOMAIN=accounts.zoho.com
# If ZOHO_BASE_URL is unset, hostname-only fallback (e.g. desk.zoho.eu):
# ZOHO_DESK_DOMAIN=desk.zoho.com

# --- Zoho Desk via MCP (optional; tried before REST when enabled)
# Python-style: mcp_endpoint_url, mcp_enabled, mcp_auth_token, force_mcp_ticket_creation
MCP_ENABLED=true
MCP_ENDPOINT_URL=https://zohoticketservicemcp-60070334819.zohomcp.in/mcp/85dbe8066318803fd7a706dd780dccc4/message
MCP_AUTH_TOKEN=
# If true and MCP is configured, do not fall back to REST OAuth when MCP fails
FORCE_MCP_TICKET_CREATION=false

# --- support-ai (Vite build-time — rebuild web after changing; enables Admin → Zoho tickets → open in Desk)
# VITE_ZOHO_DESK_ORG_ID=
# VITE_ZOHO_DESK_WEB_ORIGIN=https://desk.zoho.com
# Optional URL template (overrides origin/org path); placeholders: {orgId}, {ticketId}
# VITE_ZOHO_DESK_TICKET_URL_TEMPLATE=https://desk.zoho.com/agent/{orgId}/tickets/detail/{ticketId}

# --- Misc ---
LOG_LEVEL=INFO
